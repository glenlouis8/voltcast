# Server-side AWS credentials for the /api/forecast route (the middleman).
# These run ONLY on the server (Vercel function) — NOT prefixed NEXT_PUBLIC, so
# they never reach the browser. The route uses them to read the private S3 bucket.
#
# Set the real values in:
#   - Vercel → Project → Settings → Environment Variables
#   - a local `.env.local` for `npm run dev`
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=voltcast-forecasts
