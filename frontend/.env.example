# Base URL of the public S3 bucket (no trailing slash). The app fetches
# `${NEXT_PUBLIC_S3_BASE_URL}/forecasts/<REGION>.json` from here.
#
# Example (virtual-hosted style):
#   https://voltcast-forecasts.s3.amazonaws.com
# or a CloudFront distribution:
#   https://dxxxx.cloudfront.net
#
# Set the real value in Vercel → Project → Settings → Environment Variables,
# and in a local `.env.local` for `npm run dev`.
NEXT_PUBLIC_S3_BASE_URL=https://your-bucket.s3.amazonaws.com
